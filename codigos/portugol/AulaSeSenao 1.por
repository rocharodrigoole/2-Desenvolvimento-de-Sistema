programa {
  funcao inicio() {

    /* Desenvolva um siste,a para
    verificar se o numero é par ou impar */

    inteiro num1
    num1 = 11

    /* divide o numero por 2, verifica se o resto da divisão
    é igual a zero */

    // proposição
    num1 % 2 == 0
    
    // Se
  se (num1 % 2 == 0){
    //a verificação do se, é sempre SE VERDADEIRA
    escreva("Que legal, o numero" , num1, "é Par")
  }

    senao{
      escreva("Eita! O número" , num1, "é impar!")
    }
      }
      //senao
}
