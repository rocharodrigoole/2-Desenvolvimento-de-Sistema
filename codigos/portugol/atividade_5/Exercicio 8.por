programa {
  funcao inicio() {
    inteiro num1, num2, soma, subtracao
    escreva("Digite um numero:")
    leia(num1)
    escreva("Digite outro numero:")
    leia(num2)
    soma = num1+num2
    subtracao = num1-num2
    escreva("A Soma e a Diferença entre os numeros: ", num1, " e ", num2, " são respectivamente ", soma, " e ", subtracao)

  }
}
