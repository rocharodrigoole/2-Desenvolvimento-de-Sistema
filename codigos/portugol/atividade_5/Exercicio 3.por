programa {
  funcao inicio() {
    inteiro num1, num2, num3, num4, produto
    escreva("Digite um numero:")
    leia(num1)
    escreva("Digite um numero:")
    leia(num2)
    escreva("Digite um numero:")
    leia(num3)
    escreva("Digite um numero:")
    leia(num4)
    produto = num1+num2+num3+num4
    escreva("O Produto dos numeros: ", num1, ",", num2, ",", num3, " e ", num4, "é igual a", produto)
  }
}
